<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Library</OutputType>
    <TargetFramework>net6.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>VnExpressSeleniumTests</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- NUnit Framework -->
    <PackageReference Include="NUnit" Version="3.13.3" />
    <PackageReference Include="NUnit3TestAdapter" Version="4.4.2" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.5.0" />

    <!-- Selenium WebDriver -->
    <PackageReference Include="Selenium.WebDriver" Version="4.10.0" />
    <PackageReference Include="Selenium.Support" Version="4.10.0" />

    <!-- ChromeDriver (tự động tải đúng version) -->
    <PackageReference Include="Selenium.WebDriver.ChromeDriver" Version="114.0.5735.9000" />

    <!-- Wait Helpers -->
    <PackageReference Include="DotNetSeleniumExtras.WaitHelpers" Version="3.11.0" />
  </ItemGroup>

</Project>
